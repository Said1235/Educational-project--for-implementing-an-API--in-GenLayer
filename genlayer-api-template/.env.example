# ── Required ──────────────────────────────────────────────────────────
# Your deployed contract address from studio.genlayer.com
CONTRACT_ADDRESS=0xYourContractAddressHere

# ── Optional ───────────────────────────────────────────────────────────
# GenLayer RPC endpoint (default: studionet)
GENLAYER_RPC=https://studio.genlayer.com:8443/api

# Default private key for signing write transactions.
# If not set, a fresh studionet key is auto-generated per request.
# Callers can also pass X-Private-Key header to use their own key.
PRIVATE_KEY=0xyour_private_key_here

# HTTP port for server.js (Railway/Heroku set this automatically)
PORT=3000
